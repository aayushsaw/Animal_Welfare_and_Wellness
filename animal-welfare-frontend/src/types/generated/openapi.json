{
  "openapi": "3.0.1",
  "info": {
    "title": "Animal Welfare and Wellness API",
    "description": "Production-grade REST API for the Animal Welfare and Wellness platform.\n\n**Features:**\n- JWT Authentication with refresh token rotation\n- Role-based access control (USER, ADMIN, VOLUNTEER)\n- Animal listing, search, and adoption workflow\n- Welfare news and campaign content\n- Cloudinary image storage\n\n**Authentication:** Use `POST /api/v1/auth/login` to get a JWT token,\nthen click **Authorize** and enter: `Bearer <your-token>`\n",
    "contact": {
      "name": "Animal Welfare and Wellness",
      "email": "contact@animalwelfare.com"
    },
    "license": {
      "name": "MIT License"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local Development"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "News & Welfare Content",
      "description": "Animal welfare news, campaigns and success stories"
    },
    {
      "name": "Users",
      "description": "User profile and dashboard data"
    },
    {
      "name": "Authentication",
      "description": "Register, login, token refresh and logout"
    },
    {
      "name": "Adoptions",
      "description": "Adoption request workflow management"
    },
    {
      "name": "Animals",
      "description": "Browse, post, update, and adopt animals"
    }
  ],
  "paths": {
    "/api/v1/animals/{id}": {
      "get": {
        "tags": [
          "Animals"
        ],
        "summary": "Get a single animal by ID",
        "operationId": "getAnimal",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAnimalResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Animals"
        ],
        "summary": "Update an animal listing (poster or admin only)",
        "operationId": "updateAnimal",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnimalRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAnimalResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Animals"
        ],
        "summary": "Delete an animal listing (poster or admin only)",
        "operationId": "deleteAnimal",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseVoid"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/adoptions/{id}/review": {
      "put": {
        "tags": [
          "Adoptions"
        ],
        "summary": "Approve or reject an adoption request — Admin/Volunteer only",
        "operationId": "reviewRequest",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdoptionReviewRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAdoptionResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Register a new user account",
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAuthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Refresh access token using a valid refresh token",
        "operationId": "refresh",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAuthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Logout — revoke all refresh tokens for current user",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Login with username and password",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAuthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/animals": {
      "get": {
        "tags": [
          "Animals"
        ],
        "summary": "List available animals with pagination and category filter",
        "operationId": "getAnimals",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 12
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePagedResponseAnimalResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Animals"
        ],
        "summary": "Post a stray animal listing",
        "operationId": "createAnimal",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnimalRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAnimalResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/animals/{id}/images": {
      "post": {
        "tags": [
          "Animals"
        ],
        "summary": "Upload an image for an animal",
        "operationId": "addImage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "image"
                ],
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAnimalResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/animals/{id}/adopt": {
      "post": {
        "tags": [
          "Animals"
        ],
        "summary": "Submit an adoption request",
        "operationId": "requestAdoption",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdoptionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseAdoptionResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/users/me": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get the authenticated user's profile with contribution stats",
        "operationId": "getMyProfile",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseUserProfileResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/news": {
      "get": {
        "tags": [
          "News & Welfare Content"
        ],
        "summary": "Get paginated list of all published news articles",
        "operationId": "getAll",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 9
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePagedResponseNewsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/news/{id}": {
      "get": {
        "tags": [
          "News & Welfare Content"
        ],
        "summary": "Get a single news article by ID",
        "operationId": "getById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseNewsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/news/featured": {
      "get": {
        "tags": [
          "News & Welfare Content"
        ],
        "summary": "Get featured articles for the homepage carousel",
        "operationId": "getFeatured",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListNewsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/news/category/{category}": {
      "get": {
        "tags": [
          "News & Welfare Content"
        ],
        "summary": "Get articles by category: WELFARE_NEWS, SUCCESS_STORY, CAMPAIGN, NGO_UPDATE",
        "operationId": "getByCategory",
        "parameters": [
          {
            "name": "category",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 9
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePagedResponseNewsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/animals/stats": {
      "get": {
        "tags": [
          "Animals"
        ],
        "summary": "Platform statistics — available, adopted, total",
        "operationId": "getStats",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseMapStringLong"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/animals/my-listings": {
      "get": {
        "tags": [
          "Animals"
        ],
        "summary": "Get all animals posted by the authenticated user",
        "operationId": "getMyListings",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListAnimalResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/animals/my-adoptions": {
      "get": {
        "tags": [
          "Animals"
        ],
        "summary": "Get all animals adopted by the authenticated user",
        "operationId": "getMyAdoptions",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListAnimalResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/adoptions": {
      "get": {
        "tags": [
          "Adoptions"
        ],
        "summary": "List all adoption requests — Admin/Volunteer only",
        "operationId": "getAllRequests",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "PENDING"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponsePagedResponseAdoptionResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/adoptions/my": {
      "get": {
        "tags": [
          "Adoptions"
        ],
        "summary": "Get all adoption requests submitted by the current user",
        "operationId": "getMyRequests",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseListAdoptionResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/adoptions/{id}/cancel": {
      "delete": {
        "tags": [
          "Adoptions"
        ],
        "summary": "Cancel a pending adoption request",
        "operationId": "cancelRequest",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponseVoid"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "AnimalRequest": {
        "required": [
          "category",
          "location"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "breed": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "ageMonths": {
            "type": "integer",
            "format": "int32"
          },
          "gender": {
            "type": "string"
          },
          "color": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "location": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "description": {
            "maxLength": 2000,
            "minLength": 0,
            "type": "string"
          },
          "healthStatus": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "vaccinated": {
            "type": "boolean"
          },
          "neutered": {
            "type": "boolean"
          }
        }
      },
      "AnimalResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "breed": {
            "type": "string"
          },
          "ageMonths": {
            "type": "integer",
            "format": "int32"
          },
          "gender": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "healthStatus": {
            "type": "string"
          },
          "vaccinated": {
            "type": "boolean"
          },
          "neutered": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "primaryImageUrl": {
            "type": "string"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageInfo"
            }
          },
          "postedBy": {
            "$ref": "#/components/schemas/PostedByInfo"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ApiResponseAnimalResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/AnimalResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ImageInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "imageUrl": {
            "type": "string"
          },
          "displayOrder": {
            "type": "integer",
            "format": "int32"
          },
          "primary": {
            "type": "boolean"
          }
        }
      },
      "PostedByInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "username": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          }
        }
      },
      "AdoptionReviewRequest": {
        "required": [
          "decision"
        ],
        "type": "object",
        "properties": {
          "decision": {
            "pattern": "APPROVED|REJECTED",
            "type": "string"
          },
          "reviewNote": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "AdoptionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "animalId": {
            "type": "integer",
            "format": "int64"
          },
          "animalName": {
            "type": "string"
          },
          "animalCategory": {
            "type": "string"
          },
          "primaryImageUrl": {
            "type": "string"
          },
          "requesterId": {
            "type": "integer",
            "format": "int64"
          },
          "requesterUsername": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "reviewNote": {
            "type": "string"
          },
          "reviewerUsername": {
            "type": "string"
          },
          "reviewedAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdAt": {
