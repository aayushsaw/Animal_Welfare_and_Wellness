# ============================================================
# Animal Welfare and Wellness — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
SERVER_PORT=8080

# ── DATABASE (PostgreSQL for production) ─────────────────────
DB_URL=jdbc:postgresql://localhost:5432/animalwelfaredb
DB_DRIVER=org.postgresql.Driver
DB_USERNAME=postgres
DB_PASSWORD=yourpassword

# ── JWT ──────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters) for HS256 algorithm.
# Generate with: openssl rand -hex 32
JWT_SECRET=YourVeryLongSecretKeyThatIsAtLeast256BitsForHS256AlgorithmSecurity
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── CLOUDINARY (image CDN) ───────────────────────────────────
# Get credentials from: https://cloudinary.com/console
# Leave CLOUDINARY_API_KEY empty to fall back to local storage.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── H2 CONSOLE (development only) ───────────────────────────
# Set to false in production.
H2_CONSOLE_ENABLED=false
