animal-welfare-java/*.jar
animal-welfare-java/*.war
animal-welfare-java/.mvn/wrapper/apache-maven-*-bin.zip
animal-welfare-java/.idea/
animal-welfare-java/*.iml
animal-welfare-java/.classpath
animal-welfare-java/.project
animal-welfare-java/.settings/
animal-welfare-java/*.launch
animal-welfare-java/*.log
animal-welfare-java/logs/
animal-welfare-java/uploads/
animal-welfare-java/HELP.md

# React frontend build and dependencies
animal-welfare-frontend/node_modules/
animal-welfare-frontend/dist/
animal-welfare-frontend/.env
animal-welfare-frontend/.env.local
animal-welfare-frontend/.env.development.local
animal-welfare-frontend/.env.test.local
animal-welfare-frontend/.env.production.local
animal-welfare-frontend/npm-debug.log*
animal-welfare-frontend/yarn-debug.log*
animal-welfare-frontend/yarn-error.log*
animal-welfare-frontend/pnpm-debug.log*
animal-welfare-frontend/.oxlintrc.json

# Root environment files
.env
.env.local
.env.production

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Ignore non-required folder containing backup Tomcat and Angular files
nonrequired/
